@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    string NavClass(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        ? "nav-link active"
        : "nav-link";
    string GetRoleLabel(string? role) => role switch
    {
        UserRoles.Admin => "Администратор системы",
        UserRoles.Manager => "Менеджер",
        _ => "Пользователь"
    };
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enterprise Automation</title>
    <script>
        (() => {
            const theme = localStorage.getItem('enterprise-theme') || 'light';
            document.documentElement.dataset.theme = theme;
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EnterpriseAutomation.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Перейти к содержимому</a>
    <header class="app-shell-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid app-nav-container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNavbar" aria-controls="appNavbar"
                        aria-expanded="false" aria-label="Открыть навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="appNavbar" class="navbar-collapse collapse">
                    <ul class="navbar-nav app-nav-links">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">Панель</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Clients")" asp-controller="Clients" asp-action="Index">Клиенты</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Requests")" asp-controller="Requests" asp-action="Index">Заявки</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Orders")" asp-controller="Orders" asp-action="Index">Заказы</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("Reports")" asp-controller="Reports" asp-action="Index">Отчеты</a>
                        </li>
                    }
                    </ul>
                    <div class="app-nav-actions">
                        <button class="btn theme-toggle" type="button" data-theme-toggle aria-label="Переключить тему">
                            <span class="theme-toggle__icon" data-theme-toggle-icon>
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <circle cx="12" cy="12" r="4"></circle>
                                    <path d="M12 2v2"></path>
                                    <path d="M12 20v2"></path>
                                    <path d="m4.93 4.93 1.41 1.41"></path>
                                    <path d="m17.66 17.66 1.41 1.41"></path>
                                    <path d="M2 12h2"></path>
                                    <path d="M20 12h2"></path>
                                    <path d="m6.34 17.66-1.41 1.41"></path>
                                    <path d="m19.07 4.93-1.41 1.41"></path>
                                </svg>
                            </span>
                            <span data-theme-toggle-text>Светлая</span>
                        </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var userName = User.Identity?.Name ?? "Пользователь";
                        var roleName = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                        var roleLabel = GetRoleLabel(roleName);
                        var showRoleLabel = !string.Equals(userName, roleLabel, StringComparison.OrdinalIgnoreCase);

                        <span class="user-chip" title="Участник системы">
                            <span class="user-chip__name">@userName</span>
                            @if (showRoleLabel)
                            {
                                <span class="user-chip__divider" aria-hidden="true">•</span>
                                <span class="user-chip__role">@roleLabel</span>
                            }
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button class="btn btn-danger app-logout-btn">Выйти</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Войти</a>
                    }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-main-container">
        <main id="main-content" role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
