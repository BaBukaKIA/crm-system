@model EnterpriseAutomation.Models.Client
@{ ViewData["Title"] = "Удаление клиента"; }
<h1>Удаление клиента</h1>
<div class="alert alert-danger">Удалить клиента «@Model.Name»?</div>
<form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button class="btn btn-danger">Удалить</button> <a class="btn btn-secondary" asp-action="Index">Отмена</a></form>
