@model IEnumerable<EnterpriseAutomation.Models.Client>
@{
    ViewData["Title"] = "Клиенты";
    var filter = (EnterpriseAutomation.ViewModels.ClientFilter)ViewBag.Filter;
}

<div class="section-head">
    <div>
        <h1>Клиенты</h1>
        <p>Контакты, адреса и заметки.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Добавить</a>
</div>

<form method="get" class="filter-bar">
    <input name="Search" value="@filter.Search" class="form-control" placeholder="Поиск по названию, телефону, email" />
    <select name="Sort" class="form-select">
        <option value="name">По названию</option>
        <option value="email">По email</option>
    </select>
    <button class="btn btn-outline-primary">Найти</button>
</form>

<div class="data-table">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>ФИО/название</th>
                <th>Телефон</th>
                <th>Email</th>
                <th>Адрес</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <strong>@item.Name</strong>
                    @if (!string.IsNullOrWhiteSpace(item.Note))
                    {
                        <br />
                        <span class="text-muted small">@item.Note</span>
                    }
                </td>
                <td>@item.Phone</td>
                <td>@item.Email</td>
                <td>@item.Address</td>
                <td class="table-actions-cell">
                    <div class="table-actions">
                        <a class="btn table-action table-action--edit" asp-action="Edit" asp-route-id="@item.Id">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
                                <path d="M13.5 6.5l4 4"></path>
                            </svg>
                            <span>Изменить</span>
                        </a>
                        @if (User.IsInRole("Administrator"))
                        {
                            <a class="btn table-action table-action--delete" asp-action="Delete" asp-route-id="@item.Id">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <path d="M4 7h16"></path>
                                    <path d="M9 7V5h6v2"></path>
                                    <path d="M7 7l1 12h8l1-12"></path>
                                    <path d="M10 11v5"></path>
                                    <path d="M14 11v5"></path>
                                </svg>
                                <span>Удалить</span>
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
