@model IEnumerable<EnterpriseAutomation.Models.ServiceRequest>
@{
    ViewData["Title"] = "Заявки";
    var filter = (EnterpriseAutomation.ViewModels.RequestFilter)ViewBag.Filter;
    var isCurrentUserManager = ViewBag.IsCurrentUserManager as bool? == true;
    var currentManagerName = ViewBag.CurrentManagerName as string ?? "Текущий менеджер";
}

<div class="section-head">
    <div>
        <h1>Заявки</h1>
        <p>
            Обращения клиентов и статусы.
            @if (isCurrentUserManager)
            {
                <span class="inline-filter-note">Показаны заявки: @currentManagerName</span>
            }
        </p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Добавить</a>
</div>

<form method="get" class="filter-bar">
    <input name="Search" value="@filter.Search" class="form-control" placeholder="Клиент или описание" />
    <select name="StatusId" asp-items="ViewBag.Statuses" class="form-select">
        <option value="">Все статусы</option>
    </select>
    @if (isCurrentUserManager)
    {
        <div class="filter-chip">
            <span>Ответственный</span>
            <strong>@currentManagerName</strong>
        </div>
    }
    else
    {
        <select name="ManagerId" asp-items="ViewBag.Managers" class="form-select">
            <option value="">Все менеджеры</option>
        </select>
    }
    <input name="From" value="@filter.From?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
    <input name="To" value="@filter.To?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
    <button class="btn btn-outline-primary">Найти</button>
</form>

<div class="data-table">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Клиент</th>
                <th>Описание</th>
                <th>Статус</th>
                <th>Менеджер</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            var statusText = item.RequestStatus?.Name ?? "Неизвестно";
            var statusTone = RequestStatusTone(statusText);

            <tr>
                <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                <td>@item.Client?.Name</td>
                <td>@item.Description</td>
                <td class="status-cell">
                    <span class="status-pill status-pill--@statusTone">
                        <span class="status-pill__icon" aria-hidden="true">@Html.Raw(StatusIcon(statusTone))</span>
                        <span class="status-pill__text">@statusText</span>
                    </span>
                </td>
                <td>@item.Manager?.FullName</td>
                <td class="table-actions-cell">
                    <div class="table-actions">
                        <a class="btn table-action table-action--edit" asp-action="Edit" asp-route-id="@item.Id">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
                                <path d="M13.5 6.5l4 4"></path>
                            </svg>
                            <span>Изменить</span>
                        </a>
                        @if (User.IsInRole("Administrator"))
                        {
                            <a class="btn table-action table-action--delete" asp-action="Delete" asp-route-id="@item.Id">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <path d="M4 7h16"></path>
                                    <path d="M9 7V5h6v2"></path>
                                    <path d="M7 7l1 12h8l1-12"></path>
                                    <path d="M10 11v5"></path>
                                    <path d="M14 11v5"></path>
                                </svg>
                                <span>Удалить</span>
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@functions {
    private static string RequestStatusTone(string value)
    {
        var normalized = (value ?? string.Empty).Trim().ToLowerInvariant();

        if (normalized.Contains("закр") || normalized.Contains("выполн"))
        {
            return "success";
        }

        if (normalized.Contains("работ"))
        {
            return "warning";
        }

        if (normalized.Contains("нов"))
        {
            return "info";
        }

        return "neutral";
    }

    private static string StatusIcon(string tone)
    {
        return tone switch
        {
            "success" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M20 7L10 17l-5-5""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            "warning" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M12 7v6""></path><path d=""M12 16.5h.01""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            "info" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M12 8h.01""></path><path d=""M11 11h1v5""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            _ => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>"
        };
    }
}
