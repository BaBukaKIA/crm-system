@model EnterpriseAutomation.Models.ServiceRequest
@{
    var isCurrentUserManager = ViewBag.IsCurrentUserManager as bool? == true;
    var currentManagerName = ViewBag.CurrentManagerName as string ?? "Текущий менеджер";
}

<form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="edit-form entity-form">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <section class="form-section">
        <div class="form-section__head">
            <div>
                <h2>Детали обращения</h2>
                <p>Клиент, дата, описание и ответственный сотрудник.</p>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-field">
                <label asp-for="ClientId" class="form-label"></label>
                <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
                <span asp-validation-for="ClientId" class="text-danger field-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="CreatedAt" class="form-label"></label>
                <input asp-for="CreatedAt" type="date" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger field-validation"></span>
            </div>

            <div class="form-field form-field--full">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control form-control--textarea" rows="5" placeholder="Кратко опишите задачу или обращение клиента"></textarea>
                <span asp-validation-for="Description" class="text-danger field-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="RequestStatusId" class="form-label"></label>
                <select asp-for="RequestStatusId" asp-items="ViewBag.Statuses" class="form-select"></select>
                <span asp-validation-for="RequestStatusId" class="text-danger field-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="ManagerId" class="form-label"></label>
                @if (isCurrentUserManager)
                {
                    <input type="hidden" asp-for="ManagerId" />
                    <div class="locked-field">
                        <span class="locked-field__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"></path>
                                <path d="M4 20a8 8 0 0 1 16 0"></path>
                            </svg>
                        </span>
                        <span>
                            <strong>@currentManagerName</strong>
                            <small>назначается автоматически</small>
                        </span>
                    </div>
                }
                else
                {
                    <select asp-for="ManagerId" asp-items="ViewBag.Managers" class="form-select"></select>
                }
                <span asp-validation-for="ManagerId" class="text-danger field-validation"></span>
            </div>
        </div>
    </section>

    <div class="form-actions">
        <button class="btn btn-primary form-action-btn" type="submit">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M20 7 10 17l-5-5"></path>
            </svg>
            <span>Сохранить</span>
        </button>
        <a class="btn btn-secondary form-action-btn" asp-action="Index">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M19 12H5"></path>
                <path d="m12 19-7-7 7-7"></path>
            </svg>
            <span>Назад</span>
        </a>
    </div>
</form>
