@model EnterpriseAutomation.Models.ServiceRequest
<form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="edit-form">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6 mb-3"><label asp-for="ClientId" class="form-label"></label><select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select></div>
        <div class="col-md-6 mb-3"><label asp-for="CreatedAt" class="form-label"></label><input asp-for="CreatedAt" type="date" class="form-control" /></div>
    </div>
    <div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="4"></textarea><span asp-validation-for="Description" class="text-danger"></span></div>
    <div class="row">
        <div class="col-md-6 mb-3"><label asp-for="RequestStatusId" class="form-label"></label><select asp-for="RequestStatusId" asp-items="ViewBag.Statuses" class="form-select"></select></div>
        <div class="col-md-6 mb-3"><label asp-for="ManagerId" class="form-label"></label><select asp-for="ManagerId" asp-items="ViewBag.Managers" class="form-select"></select></div>
    </div>
    <button class="btn btn-primary">Сохранить</button> <a class="btn btn-secondary" asp-action="Index">Назад</a>
</form>
