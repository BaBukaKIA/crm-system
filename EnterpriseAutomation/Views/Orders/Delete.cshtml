@model EnterpriseAutomation.Models.Order
@{ ViewData["Title"] = "Удаление заказа"; }
<h1>Удаление заказа</h1>
<div class="alert alert-danger">Удалить заказ #@Model.Id для клиента «@Model.ServiceRequest?.Client?.Name»?</div>
<form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button class="btn btn-danger">Удалить</button> <a class="btn btn-secondary" asp-action="Index">Отмена</a></form>
