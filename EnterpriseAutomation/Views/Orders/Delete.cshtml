@model EnterpriseAutomation.Models.Order
@{
    ViewData["Title"] = "Удаление заказа";
}

<div class="page-head">
    <h1>Удаление заказа</h1>
    <p>Проверьте запись перед удалением.</p>
</div>

<div class="delete-panel">
    <div class="alert alert-danger">Удалить заказ #@Model.Id?</div>
    <form asp-action="Delete" method="post" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger">Удалить</button>
        <a class="btn btn-secondary" asp-action="Index">Отмена</a>
    </form>
</div>
