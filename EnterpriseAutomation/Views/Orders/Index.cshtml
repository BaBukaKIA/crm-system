@model IEnumerable<EnterpriseAutomation.Models.Order>
@{
    ViewData["Title"] = "Заказы";
    var filter = (EnterpriseAutomation.ViewModels.OrderFilter)ViewBag.Filter;
}

<div class="section-head">
    <div>
        <h1>Заказы</h1>
        <p>Состав услуг, суммы, сроки и статусы.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Добавить</a>
</div>

<form method="get" class="filter-bar">
    <input name="Search" value="@filter.Search" class="form-control" placeholder="Клиент или услуга" />
    <select name="PaymentStatusId" asp-items="ViewBag.PaymentStatuses" class="form-select">
        <option value="">Оплата</option>
    </select>
    <select name="ExecutionStatusId" asp-items="ViewBag.ExecutionStatuses" class="form-select">
        <option value="">Исполнение</option>
    </select>
    <input name="From" value="@filter.From?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
    <input name="To" value="@filter.To?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
    <button class="btn btn-outline-primary">Найти</button>
</form>

<div class="data-table">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Клиент</th>
                <th>Услуги</th>
                <th>Сумма</th>
                <th>Срок</th>
                <th>Оплата</th>
                <th>Исполнение</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            var paymentText = item.PaymentStatus?.Name ?? "Неизвестно";
            var paymentTone = PaymentStatusTone(paymentText);
            var executionText = item.ExecutionStatus?.Name ?? "Неизвестно";
            var executionTone = ExecutionStatusTone(executionText);

            <tr>
                <td>
                    <strong>@item.ServiceRequest?.Client?.Name</strong><br />
                    <span class="text-muted small">Заявка #@item.ServiceRequestId</span>
                </td>
                <td>@item.Services</td>
                <td>@item.Amount.ToString("N2") ₽</td>
                <td>@item.DueDate.ToString("dd.MM.yyyy")</td>
                <td class="status-cell">
                    <span class="status-pill status-pill--@paymentTone">
                        <span class="status-pill__icon" aria-hidden="true">@Html.Raw(StatusIcon(paymentTone))</span>
                        <span class="status-pill__text">@paymentText</span>
                    </span>
                </td>
                <td class="status-cell">
                    <span class="status-pill status-pill--@executionTone">
                        <span class="status-pill__icon" aria-hidden="true">@Html.Raw(StatusIcon(executionTone))</span>
                        <span class="status-pill__text">@executionText</span>
                    </span>
                </td>
                <td class="table-actions-cell">
                    <div class="table-actions">
                        <a class="btn table-action table-action--edit" asp-action="Edit" asp-route-id="@item.Id">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
                                <path d="M13.5 6.5l4 4"></path>
                            </svg>
                            <span>Изменить</span>
                        </a>
                        @if (User.IsInRole("Administrator"))
                        {
                            <a class="btn table-action table-action--delete" asp-action="Delete" asp-route-id="@item.Id">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <path d="M4 7h16"></path>
                                    <path d="M9 7V5h6v2"></path>
                                    <path d="M7 7l1 12h8l1-12"></path>
                                    <path d="M10 11v5"></path>
                                    <path d="M14 11v5"></path>
                                </svg>
                                <span>Удалить</span>
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@functions {
    private static string PaymentStatusTone(string value)
    {
        var normalized = (value ?? string.Empty).Trim().ToLowerInvariant();

        if (normalized.Contains("не") && normalized.Contains("оплач"))
        {
            return "danger";
        }

        if (normalized.Contains("част"))
        {
            return "warning";
        }

        if (normalized.Contains("оплач"))
        {
            return "success";
        }

        return "neutral";
    }

    private static string ExecutionStatusTone(string value)
    {
        var normalized = (value ?? string.Empty).Trim().ToLowerInvariant();

        if (normalized.Contains("заверш") || normalized.Contains("готов"))
        {
            return "success";
        }

        if (normalized.Contains("выполн"))
        {
            return "warning";
        }

        if (normalized.Contains("план"))
        {
            return "info";
        }

        return "neutral";
    }

    private static string StatusIcon(string tone)
    {
        return tone switch
        {
            "success" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M20 7L10 17l-5-5""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            "warning" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M12 7v6""></path><path d=""M12 16.5h.01""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            "info" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M12 8h.01""></path><path d=""M11 11h1v5""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            "danger" => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><path d=""M15 9l-6 6""></path><path d=""M9 9l6 6""></path><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>",
            _ => @"<svg viewBox=""0 0 24 24"" aria-hidden=""true""><circle cx=""12"" cy=""12"" r=""9.2""></circle></svg>"
        };
    }
}
